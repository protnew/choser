                                            <span style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                                                <span>{v.emoji}</span><strong>{v.name}</strong>
                                                <span style={{ fontSize: 11, color: v.recommendation && v.recommendation !== 'insufficient_data' ? '#22c55e' : tS }}>{v.recommendation || '—'}</span>
                                                {v.score ? <span style={{ fontSize: 11, color: '#f59e0b' }}>score:{v.score}</span> : null}
                                                {v.confidence ? <span style={{ fontSize: 11, color: tS }}>conf:{v.confidence}/10</span> : null}
                                            </span>
                                            <span style={{ fontSize: 10, color: tS, fontFamily: 'monospace' }}>{d.provider || '?'} · {d.model || '?'} · {d.duration_ms ? `${(d.duration_ms / 1000).toFixed(1)}s` : '?'} · {d.tokens_in || 0}↓{d.tokens_out || 0}↑</span>
                                        </summary>
                                        <div style={{ padding: 14, fontSize: 12, lineHeight: 1.7, color: tM, whiteSpace: 'pre-wrap', maxHeight: 400, overflow: 'auto', borderTop: `1px solid ${brd}` }}>
                                            {j?.analysis && <div style={{ marginBottom: 10, padding: '8px 12px', background: bgI, borderRadius: 6, borderLeft: '3px solid #3b82f6', color: tS }}>{j.analysis}</div>}
                                            {v.response}
                                        </div>
                                    </details>
                                );
                            })}
                            {lastResult.debug && (
                                <div style={{ padding: 12, background: bgI, borderRadius: 8, fontSize: 11, color: tS, fontFamily: 'monospace' }}>
                                    <strong>Trace:</strong><br />{lastResult.debug.map((d, i) => `${d.persona}: ${d.status} ${d.ms}ms (${d.provider || '?'}/${d.model || '?'})`).join(' → ')}
                                </div>
                            )}
                            {lastResult.consensus?.recommendations && (
                                <div style={{ padding: 12, background: bgI, borderRadius: 8 }}>
                                    <div style={{ fontSize: 12, fontWeight: 700, color: tM, marginBottom: 8 }}>📊 Голосование</div>
                                    {Object.entries(lastResult.consensus.recommendations).map(([r, w]) => (
                                        <div key={r} style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 4 }}>
                                            <div style={{ flex: 1, fontSize: 12, color: tM }}>{r}</div>
                                            <div style={{ width: Math.round(w * 30), height: 14, background: '#3b82f6', borderRadius: 4, opacity: 0.7 }} />
                                            <div style={{ fontSize: 11, color: tS, width: 30, textAlign: 'right' }}>{w.toFixed(1)}</div>
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>
                    )}
                </div>

                {/* INPUT */}
                <div style={{ padding: '12px 20px', borderTop: `1px solid ${brd}`, display: 'flex', gap: 8, background: bg }}>
                    <input value={input} onChange={e => setInput(e.target.value)} onKeyDown={e => { if (e.key === 'Enter') { e.preventDefault(); runCouncil(); } }} placeholder={topic ? `Вопрос по «${topic}»...` : 'Опишите задачу слева...'} disabled={!topic || running} style={{ flex: 1, padding: '10px 14px', border: `1px solid ${brd}`, borderRadius: 8, fontSize: 14, background: topic ? bg : bgI, color: tM }} />
                    <button onClick={runCouncil} disabled={!topic || running || !loaded} style={{ padding: '10px 24px', background: running ? (isDark ? '#334155' : '#94a3b8') : 'linear-gradient(135deg, #f59e0b, #ef4444)', color: '#fff', border: 'none', borderRadius: 8, cursor: running ? 'default' : 'pointer', fontSize: 14, fontWeight: 600 }}>{running ? '⏳' : '🚀 Запустить'}</button>
                </div>
            </div>
        </div>
    );
}
