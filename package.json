        "ag-grid-react": "^31.3.1",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.9.0",
        "drizzle-orm": "^0.45.1",
        "echarts": "^6.0.0",
        "echarts-for-react": "^3.0.6",
        "exceljs": "^4.4.0",
        "hono": "^4.0.0",
        "html2canvas": "^1.4.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
