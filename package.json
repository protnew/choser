{
    "name": "choser-engine",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "dev:server": "node edp/src/server.js",
        "dev:full": "npx concurrently \"npm run dev\" \"npm run dev:server\"",
