# Gemini API Key (из Google AI Studio)
GOOGLE_API_KEY=your_gemini_api_key_here

# URL вашего развернутого Choser (например, https://choser-app.pages.dev/api/tables)
CHOSER_API_URL=https://choser-app.pages.dev/api/tables

# JWT токен для авторизации (можно взять из localStorage браузера после входа)
CHOSER_TOKEN=your_jwt_token_here
