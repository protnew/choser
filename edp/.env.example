# ─── Choser EDP Configuration ───

# Server
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=*
NODE_ENV=production

# Auth
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production

# LLM Providers (at least one required)
# ZAI / GLM-5.1 (primary)
ZAI_API_KEY=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Google Gemini (fallback)
GOOGLE_API_KEY=
# Real OpenAI (optional, NOT ZAI proxy)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Local Qwen (optional)
QWEN_BASE_URL=http://127.0.0.1:8081/v1

# Database
DB_PATH=./data/choser.db

# Docker resource limits
MEM_LIMIT=1g
CPUS=2

# MCP Transport
MCP_TRANSPORT=sse
